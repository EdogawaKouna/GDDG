<Window x:Class="GameDesignDocGenerator.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ 初始设置"
        Height="400" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🎮 欢迎使用游戏机制文案生成器" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="首次使用需要配置 DeepSeek API Key" 
                   Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="2" Background="#FFF3CD" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock FontWeight="Bold" Foreground="#856404">🔑 如何获取 API Key？</TextBlock>
                <TextBlock Foreground="#856404" TextWrapping="Wrap" Margin="0,5,0,0">
                    1. 打开 任意AI大模型 注册账号
                    2. 进入 API Keys 页面创建新 Key
                    3. 复制 Key 粘贴到下方输入框
                    4. 充值少量余额（生成一次约 0.02 元）
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="API Key:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBox x:Name="txtApiKey" Grid.Column="1" Height="30"
                     ToolTip="格式：sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"/>
        </Grid>

        <Button x:Name="btnSave" Grid.Row="4" Content="✅ 保存并开始使用"
                Width="200" Height="40" Background="#FFD700" FontWeight="Bold"
                Click="BtnSave_Click" HorizontalAlignment="Center"/>

        <TextBlock x:Name="txtError" Grid.Row="5" Foreground="Red" 
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
    </Grid>
</Window>